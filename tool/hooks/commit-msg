#!/usr/bin/env bash
#
# Test-presence gate. Blocks a commit that changes behavior code unless it also
# stages a test, or carries an explicit waiver. This is the mechanical backstop
# for "every behavior fix gets a test" — `check.sh` runs the existing tests but
# can't tell that a change introduced behavior without a guard for it.
#
# Behavior code = the adapters / core / bridge / site lib (not generated files).
# Tests = anything under a `test/` dir, plus the shared conformance spec package
# (`a2ui_craft_testing/lib`, where the geometry/behavioral cases live).
#
# Waiver (use sparingly, with a real reason — it lands in git history):
#   add a commit-message line:  Test: none (<reason>)
# Or bypass the hook entirely with:  git commit --no-verify
#
# Enable once per clone:  git config core.hooksPath tool/hooks
set -euo pipefail

msg_file="$1"
staged=$(git diff --cached --name-only --diff-filter=ACM)

behavior=$(printf '%s\n' "$staged" \
  | grep -E '^(packages/(a2ui_craft|a2ui_craft_bridge|a2ui_craft_flutter|a2ui_craft_jaspr)/lib/|site/(lib|web)/)' \
  | grep -vE '\.g\.dart$' || true)

tests=$(printf '%s\n' "$staged" \
  | grep -E '(/test/|^packages/a2ui_craft_testing/lib/)' || true)

if [ -n "$behavior" ] && [ -z "$tests" ]; then
  if grep -qiE '^[[:space:]]*Test:[[:space:]]*none' "$msg_file"; then
    exit 0
  fi
  {
    echo ""
    echo "✗ commit blocked: behavior code changed, but no test is staged."
    echo ""
    echo "  Changed (needs a test, or an explicit waiver):"
    printf '%s\n' "$behavior" | sed 's/^/      /'
    echo ""
    echo "  Add a test — geometry/behavioral conformance lives in"
    echo "  packages/a2ui_craft_testing/lib/src/, and verify it fails on the"
    echo "  pre-fix behavior (test the test)."
    echo ""
    echo "  If a test genuinely does not apply (docs-shaped change, pure"
    echo "  refactor, hard-to-unit-test UI), add a commit-message line:"
    echo "      Test: none (<reason>)"
  } >&2
  exit 1
fi
exit 0
